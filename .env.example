# local-budget environment overrides.
#
# Copy this file to `.env` and fill in only the values you need. `.env` is
# gitignored. The CLI auto-loads it at startup; real shell-set vars take
# precedence (useful in containers, where compose injects vars directly).
#
# Every variable below is OPTIONAL for the host CLI on loopback (127.0.0.1).
#
# The AGENT needs NO key here. You talk to your money from a Claude Code session
# pointed at this repo: the committed `.mcp.json` wires up `uv run budget-mcp`
# (a stdio MCP server) and the `.claude/skills/budget-*` skills auto-load. The
# server runs no inference — your Claude Code subscription auth drives the
# session, so no token belongs in this file for it.

# --- API auth (REQUIRED only for a non-loopback dashboard bind) ---------------
# Bearer token gating /api/* on the `budget serve` dashboard. The server REFUSES
# to bind a non-loopback host without it, AND rejects a token shorter than 32
# chars (a weak token must never gate full bank data on the LAN). Loopback
# host-CLI dev needs nothing.
#
# Generate a fresh token:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# LOCAL_BUDGET_API_TOKEN=paste-the-generated-token-here

# --- Paths --------------------------------------------------------------------
# Defaults are project-relative: ./data, ./briefings. Override only when you
# bind-mount volumes (e.g. /data and /data/briefings — briefings MUST live under
# a writable mount).
# LOCAL_BUDGET_DATA_DIR=/data
# LOCAL_BUDGET_BRIEFINGS_DIR=/data/briefings

# --- Web server ---------------------------------------------------------------
# `budget serve` defaults to 127.0.0.1 (loopback-only). Set 0.0.0.0 only when a
# reverse proxy must reach it (and then LOCAL_BUDGET_API_TOKEN is required).
# LOCAL_BUDGET_HOST=0.0.0.0

# --- Read-only-ish deployment (raw intake disabled) ---------------------------
# When set, the raw-file ingestion routes (/api/upload, /api/intake/run,
# /api/intake/undo) return 403 — raw bank exports (full account numbers) can
# never enter that process. Do intake on the host CLI.
# LOCAL_BUDGET_NO_INTAKE=1
